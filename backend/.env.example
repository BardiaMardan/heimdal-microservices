# App Settings
PROJECT_NAME="Heimdall"
API_V1_STR="/api/v1"

# Database
# Native Postgres (no Docker required): brew install postgresql@16
#   createuser -s heimdall && createdb -O heimdall heimdall
DATABASE_URL="postgresql+psycopg://heimdall:heimdall@localhost:5432/heimdall"

# Security
# Generate a real secret key using: openssl rand -hex 32
SECRET_KEY="development_secret_key_change_me_in_production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=11520
BACKEND_CORS_ORIGINS=["http://localhost:3000"] # 8 days

# MQTT telemetry data plane
# Native broker (no Docker): brew install mosquitto && brew services start mosquitto
# Under docker compose the host is the service name "mosquitto".
MQTT_BROKER_HOST="localhost"
MQTT_BROKER_PORT=1883
MQTT_TOPIC_PREFIX="heimdall"
MQTT_QOS=1
INGESTION_ENABLED=true
